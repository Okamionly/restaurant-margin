# RestauMargin — Environment Variables Template
# Copy to .env (never commit .env — it is in .gitignore)
# All variables marked REQUIRED must be set on Vercel before the first payment attempt.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"

# ── Authentication ────────────────────────────────────────────────────────────
# REQUIRED — Must be a 32+ char random secret. Boot fails if absent.
JWT_SECRET="changeme-generate-a-real-32-char-secret"

# ── Stripe — REQUIRED for billing ────────────────────────────────────────────
# REQUIRED — Stripe secret key
STRIPE_SECRET_KEY="sk_test_..."
# REQUIRED — Webhook signing secret. Without this all webhook requests are rejected.
STRIPE_WEBHOOK_SECRET="whsec_..."
# Stripe Price IDs
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_PRO_ANNUAL="price_..."
STRIPE_PRICE_BUSINESS_MONTHLY="price_..."
STRIPE_PRICE_BUSINESS_ANNUAL="price_..."

# ── Anthropic ─────────────────────────────────────────────────────────────────
# REQUIRED — All 19 AI actions fail without this
ANTHROPIC_API_KEY="sk-ant-..."

# ── Email (Resend) ────────────────────────────────────────────────────────────
# REQUIRED for activation codes, password reset, campaigns
RESEND_API_KEY="re_..."

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Sentry (error monitoring) ─────────────────────────────────────────────────
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# ── Cron + internal security ──────────────────────────────────────────────────
CRON_SECRET="changeme-cron-secret"
INTERNAL_WEBHOOK_SECRET="changeme-internal-secret"
ACTIVATION_SECRET="changeme-activation-secret"

# ── Search APIs (optional) ────────────────────────────────────────────────────
EXA_API_KEY=""
TAVILY_API_KEY=""

# ── App config ────────────────────────────────────────────────────────────────
NODE_ENV="production"
FRONTEND_URL="https://www.restaumargin.fr"
