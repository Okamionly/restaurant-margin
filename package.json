{
  "name": "restaurant-margin",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:client": "cd client && npm run build",
    "build:server": "cd server && npm run build",
    "build": "npm run build:server && npm run build:client",
    "build:vercel": "cd server && npx prisma generate && cd ../client && npx vite build",
    "seed": "cd server && npx tsx src/seed.ts",
    "parse-pdf": "npx tsx scripts/parse-supplier-pdf.ts"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.4",
    "pdf-parse": "^1.1.1",
    "prisma": "^5.22.0",
    "recharts": "^3.8.0",
    "resend": "^6.9.4"
  }
}
