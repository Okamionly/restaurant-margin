generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("chef") // admin, chef
  createdAt    DateTime @default(now())

  @@map("users")
}

model Supplier {
  id           Int      @id @default(autoincrement())
  name         String
  phone        String?
  email        String?
  address      String?
  city         String?
  postalCode   String?
  region       String?
  country      String   @default("France")
  siret        String?
  website      String?
  notes        String?
  categories   String[]
  contactName  String?
  delivery     Boolean  @default(true)
  minOrder     String?
  paymentTerms String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  ingredients  Ingredient[]
  rfqSuppliers RFQSupplier[]
  rfqQuotes    RFQQuote[]

  @@map("suppliers")
}

model Ingredient {
  id           Int                @id @default(autoincrement())
  name         String
  unit         String
  pricePerUnit Float
  supplier     String?
  supplierId   Int?
  supplierRef  Supplier?          @relation(fields: [supplierId], references: [id])
  category     String
  allergens    String[]           @default([])
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  recipes      RecipeIngredient[]
  inventoryItem InventoryItem?
  rfqItems     RFQItem[]
  priceHistory PriceHistory[]

  @@map("ingredients")
}

model PriceHistory {
  id           Int        @id @default(autoincrement())
  ingredientId Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  price        Float
  source       String?    // "manual", "invoice", "rfq"
  invoiceRef   String?
  createdAt    DateTime   @default(now())

  @@map("price_history")
}

model Invoice {
  id           Int            @id @default(autoincrement())
  supplierId   Int?
  supplierName String
  invoiceNumber String?
  invoiceDate  DateTime?
  totalHT      Float?
  totalTTC     Float?
  imageUrl     String?
  status       String         @default("pending") // pending, processed, error
  rawText      String?
  createdAt    DateTime       @default(now())
  items        InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id           Int      @id @default(autoincrement())
  invoiceId    Int
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productName  String
  quantity     Float?
  unit         String?
  unitPrice    Float?
  totalPrice   Float?
  matched      Boolean  @default(false)
  ingredientId Int?

  @@map("invoice_items")
}

model MenuSales {
  id        Int      @id @default(autoincrement())
  recipeId  Int
  date      DateTime @default(now())
  quantity  Int      @default(1)
  revenue   Float?

  @@map("menu_sales")
}

model RFQ {
  id          Int           @id @default(autoincrement())
  title       String
  status      String        @default("draft") // draft, sent, closed
  dueDate     DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  items       RFQItem[]
  suppliers   RFQSupplier[]

  @@map("rfqs")
}

model RFQItem {
  id           Int        @id @default(autoincrement())
  rfqId        Int
  ingredientId Int
  quantity     Float
  rfq          RFQ        @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quotes       RFQQuote[]

  @@unique([rfqId, ingredientId])
  @@map("rfq_items")
}

model RFQSupplier {
  id         Int      @id @default(autoincrement())
  rfqId      Int
  supplierId Int
  rfq        RFQ      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  @@unique([rfqId, supplierId])
  @@map("rfq_suppliers")
}

model RFQQuote {
  id         Int      @id @default(autoincrement())
  rfqItemId  Int
  supplierId Int
  unitPrice  Float?
  notes      String?
  selected   Boolean  @default(false)
  rfqItem    RFQItem  @relation(fields: [rfqItemId], references: [id], onDelete: Cascade)
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  @@unique([rfqItemId, supplierId])
  @@map("rfq_quotes")
}

model Recipe {
  id               Int                @id @default(autoincrement())
  name             String
  category         String
  sellingPrice     Float
  nbPortions       Int                @default(1)
  description      String?
  prepTimeMinutes  Int?
  cookTimeMinutes  Int?
  laborCostPerHour Float              @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  ingredients      RecipeIngredient[]

  @@map("recipes")
}

model RecipeIngredient {
  id           Int        @id @default(autoincrement())
  recipeId     Int
  ingredientId Int
  quantity     Float
  wastePercent Float      @default(0)
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([recipeId, ingredientId])
  @@map("recipe_ingredients")
}

model InventoryItem {
  id                  Int        @id @default(autoincrement())
  ingredientId        Int
  ingredient          Ingredient @relation(fields: [ingredientId], references: [id])
  currentStock        Float      @default(0)
  unit                String
  minStock            Float      @default(0)
  maxStock            Float?
  lastRestockDate     DateTime?
  lastRestockQuantity Float?
  notes               String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@unique([ingredientId])
  @@map("inventory_items")
}
