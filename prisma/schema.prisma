generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                Int                @id @default(autoincrement())
  email             String             @unique
  passwordHash      String
  name              String
  role              String             @default("chef") // admin, chef
  plan              String             @default("basic") // basic, pro, business
  stripeCustomerId  String?
  stripeSubId       String?
  emailVerified     Boolean            @default(true)
  verificationToken String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  acceptedCguAt     DateTime?
  trialEndsAt       DateTime?
  createdAt         DateTime           @default(now())
  ownedRestaurants  Restaurant[]       @relation("OwnedRestaurants")
  memberships       RestaurantMember[]

  @@map("users")
}

model ActivationCode {
  id              Int       @id @default(autoincrement())
  code            String    @unique
  plan            String // basic, pro, business
  used            Boolean   @default(false)
  usedBy          String? // email of user who used it
  usedAt          DateTime?
  stripePaymentId String?
  createdAt       DateTime  @default(now())

  @@index([code])
  @@map("activation_codes")
}

model Restaurant {
  id                Int                @id @default(autoincrement())
  name              String
  address           String?
  cuisineType       String?
  phone             String?
  coversPerDay      Int                @default(80)
  ownerId           Int
  owner             User               @relation("OwnedRestaurants", fields: [ownerId], references: [id])
  members           RestaurantMember[]
  ingredients       Ingredient[]
  recipes           Recipe[]
  suppliers         Supplier[]
  inventory         InventoryItem[]
  invoices          Invoice[]
  priceHistory      PriceHistory[]
  menuSales         MenuSale[]
  devis             Devis[]
  conversations     Conversation[]
  financialEntries  FinancialEntry[]
  wasteLogs         WasteLog[]
  haccpTemperatures HaccpTemperature[]
  haccpCleanings    HaccpCleaning[]
  employees         Employee[]
  shifts            Shift[]
  timeEntries       TimeEntry[]
  seminaires        Seminaire[]
  marketplaceOrders MarketplaceOrder[]
  newsItems         NewsItem[]
  customerFeedback  CustomerFeedback[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("restaurants")
}

model RestaurantMember {
  id           Int        @id @default(autoincrement())
  userId       Int
  restaurantId Int
  role         String     @default("member") // owner, admin, member
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@index([userId])
  @@index([restaurantId])
  @@map("restaurant_members")
}

model Supplier {
  id            Int          @id @default(autoincrement())
  name          String
  phone         String?
  email         String?
  address       String?
  city          String?
  postalCode    String?
  region        String?
  country       String       @default("France")
  siret         String?
  website       String?
  notes         String?
  categories    String[]
  contactName   String?
  delivery      Boolean      @default(true)
  minOrder      String?
  paymentTerms  String?
  whatsappPhone String?
  restaurantId  Int
  restaurant    Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  ingredients   Ingredient[]

  @@index([restaurantId])
  @@map("suppliers")
}

model Ingredient {
  id            Int                @id @default(autoincrement())
  name          String
  unit          String
  pricePerUnit  Float
  supplier      String?
  supplierId    Int?
  supplierRef   Supplier?          @relation(fields: [supplierId], references: [id])
  category      String
  allergens     String[]           @default([])
  barcode       String?
  deletedAt     DateTime?
  restaurantId  Int
  restaurant    Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  recipes       RecipeIngredient[]
  inventoryItem InventoryItem?
  wasteLogs     WasteLog[]
  priceHistory  PriceHistory[]

  @@index([restaurantId, name])
  @@index([restaurantId, category])
  @@index([restaurantId, barcode])
  @@index([supplierId])
  @@map("ingredients")
}

model Recipe {
  id               Int                @id @default(autoincrement())
  name             String
  category         String
  sellingPrice     Float
  nbPortions       Int                @default(1)
  description      String?
  prepTimeMinutes  Int?
  cookTimeMinutes  Int?
  laborCostPerHour Float              @default(0)
  deletedAt        DateTime?
  restaurantId     Int
  restaurant       Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  ingredients      RecipeIngredient[]

  @@index([restaurantId, category])
  @@map("recipes")
}

model RecipeIngredient {
  id           Int        @id @default(autoincrement())
  recipeId     Int
  ingredientId Int
  quantity     Float
  wastePercent Float      @default(0)
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([recipeId, ingredientId])
  @@map("recipe_ingredients")
}

model InventoryItem {
  id                  Int        @id @default(autoincrement())
  ingredientId        Int
  ingredient          Ingredient @relation(fields: [ingredientId], references: [id])
  currentStock        Float      @default(0)
  unit                String
  minStock            Float      @default(0)
  maxStock            Float?
  minQuantity         Float      @default(0)
  lastRestockDate     DateTime?
  lastRestockQuantity Float?
  notes               String?
  restaurantId        Int
  restaurant          Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@unique([ingredientId])
  @@index([restaurantId])
  @@map("inventory_items")
}

model Invoice {
  id            Int           @id @default(autoincrement())
  supplierName  String
  invoiceNumber String
  invoiceDate   String
  totalAmount   Float
  status        String        @default("pending")
  restaurantId  Int
  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  items         InvoiceItem[]

  @@index([supplierName])
  @@index([status])
  @@index([restaurantId, createdAt])
  @@index([restaurantId, status])
  @@map("invoices")
}

model InvoiceItem {
  id           Int     @id @default(autoincrement())
  invoiceId    Int
  invoice      Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productName  String
  quantity     Float
  unit         String
  unitPrice    Float
  total        Float
  ingredientId Int?

  @@index([invoiceId])
  @@map("invoice_items")
}

model PriceHistory {
  id           Int        @id @default(autoincrement())
  ingredientId Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  price        Float
  date         String
  source       String     @default("manual")
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@index([ingredientId])
  @@index([date])
  @@index([ingredientId, date])
  @@index([ingredientId, createdAt])
  @@map("price_history")
}

model MenuSale {
  id           Int        @id @default(autoincrement())
  recipeId     Int
  recipeName   String
  quantity     Int
  revenue      Float
  date         String
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@index([recipeId])
  @@index([date])
  @@index([recipeId, date])
  @@map("menu_sales")
}

model Devis {
  id            Int         @id @default(autoincrement())
  number        String // DEV-2026-001
  clientName    String
  clientEmail   String?
  clientPhone   String?
  clientAddress String?
  subject       String
  status        String      @default("draft") // draft, sent, accepted, rejected
  totalHT       Float       @default(0)
  totalTTC      Float       @default(0)
  tvaRate       Float       @default(20)
  validUntil    String?
  notes         String?
  restaurantId  Int
  restaurant    Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items         DevisItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([restaurantId, status])
  @@map("devis")
}

model DevisItem {
  id          Int    @id @default(autoincrement())
  devisId     Int
  devis       Devis  @relation(fields: [devisId], references: [id], onDelete: Cascade)
  description String
  quantity    Float
  unitPrice   Float
  total       Float

  @@index([devisId])
  @@map("devis_items")
}

model FinancialEntry {
  id           Int        @id @default(autoincrement())
  date         String // YYYY-MM-DD
  type         String // revenue, expense
  category     String // Matières premières, Personnel, Loyer, Énergie, etc.
  label        String // Description
  amount       Float
  tvaRate      Float      @default(20)
  tvaAmount    Float      @default(0)
  paymentMode  String? // CB, Espèces, Chèque, Virement, Ticket resto
  reference    String? // Invoice number, receipt number
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@index([restaurantId, date])
  @@index([restaurantId, type])
  @@map("financial_entries")
}

model WasteLog {
  id           Int        @id @default(autoincrement())
  ingredientId Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Float
  unit         String
  reason       String // expired, spoiled, overproduction, damaged, other
  costImpact   Float // quantity * ingredient pricePerUnit
  date         String // YYYY-MM-DD
  notes        String?
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@index([restaurantId, date])
  @@map("waste_logs")
}

model Employee {
  id           Int         @id @default(autoincrement())
  name         String
  role         String // Chef, Commis, Serveur, Plongeur, Barman, Manager
  email        String?
  phone        String?
  hourlyRate   Float       @default(12)
  color        String      @default("#3b82f6")
  active       Boolean     @default(true)
  restaurantId Int
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  shifts       Shift[]
  timeEntries  TimeEntry[]
  createdAt    DateTime    @default(now())

  @@index([restaurantId])
  @@map("employees")
}

model Shift {
  id           Int        @id @default(autoincrement())
  employeeId   Int
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date         String // YYYY-MM-DD
  startTime    String // HH:MM
  endTime      String // HH:MM
  type         String // Matin, Midi, Soir, Coupure
  notes        String?
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@index([restaurantId, date])
  @@index([employeeId, date])
  @@map("shifts")
}

model TimeEntry {
  id           Int        @id @default(autoincrement())
  employeeId   Int
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date         String // YYYY-MM-DD
  punchIn      DateTime
  punchOut     DateTime?
  totalMinutes Int?
  notes        String?
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@index([restaurantId, date])
  @@index([employeeId, date])
  @@map("time_entries")
}

model HaccpTemperature {
  id           Int        @id @default(autoincrement())
  zone         String // Frigo, Congélateur, Plats chauds, Réception
  temperature  Float
  status       String     @default("conforme") // conforme, non_conforme, en_attente
  recordedBy   String?
  notes        String?
  date         String // YYYY-MM-DD
  time         String? // HH:MM
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@index([restaurantId, date])
  @@map("haccp_temperatures")
}

model HaccpCleaning {
  id           Int        @id @default(autoincrement())
  zone         String // Cuisine, Salle, Toilettes, Chambre froide, etc.
  task         String // Description of cleaning task
  status       String     @default("en_attente") // fait, en_attente, non_fait
  doneBy       String?
  date         String
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@index([restaurantId, date])
  @@map("haccp_cleanings")
}

model Seminaire {
  id           Int        @id @default(autoincrement())
  title        String
  clientName   String
  clientEmail  String?
  clientPhone  String?
  eventType    String // Séminaire, Mariage, Anniversaire, Corporate, Autre
  date         String // YYYY-MM-DD
  startTime    String?
  endTime      String?
  guestCount   Int        @default(20)
  status       String     @default("demande") // demande, devis_envoye, confirme, en_cours, solde, annule
  budget       Float?
  menuDetails  String?
  equipment    String[]   @default([])
  notes        String?
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([restaurantId, status])
  @@index([restaurantId, date])
  @@map("seminaires")
}

model MarketplaceOrder {
  id               Int                    @id @default(autoincrement())
  supplierName     String
  supplierId       Int?
  status           String                 @default("draft") // draft, sent, confirmed, received, cancelled, claimed
  totalHT          Float                  @default(0)
  notes            String?
  expectedDelivery DateTime?
  receivedAt       DateTime?
  restaurantId     Int
  restaurant       Restaurant             @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items            MarketplaceOrderItem[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([restaurantId, status])
  @@index([restaurantId, createdAt])
  @@map("marketplace_orders")
}

model MarketplaceOrderItem {
  id               Int              @id @default(autoincrement())
  orderId          Int
  order            MarketplaceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productName      String
  quantity         Float
  unit             String
  unitPrice        Float
  total            Float
  ingredientId     Int?
  receivedQuantity Float?

  @@index([orderId])
  @@map("marketplace_order_items")
}

model Conversation {
  id           String     @id
  name         String
  participants String[]
  lastMessage  String     @default("")
  unreadCount  Int        @default(0)
  isGroup      Boolean    @default(false)
  avatar       String     @default("")
  starred      Boolean    @default(false)
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  messages     Message[]

  @@map("conversations")
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  senderName     String
  content        String
  timestamp      String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@map("messages")
}

model Referral {
  id            Int      @id @default(autoincrement())
  referrerId    Int?
  refereeId     Int?
  referralCode  String   @unique
  status        String   @default("pending")
  rewardApplied Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@map("referrals")
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  userId       Int
  restaurantId Int
  action       String // CREATE, UPDATE, DELETE, RESTORE
  entityType   String // ingredient, recipe, supplier, inventory, order
  entityId     Int
  changes      Json? // { field: { old: value, new: value } }
  createdAt    DateTime @default(now())

  @@index([restaurantId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model NewsItem {
  id            Int         @id @default(autoincrement())
  restaurantId  Int?
  title         String
  content       String
  type          String
  priority      String      @default("normal")
  dismissed     Boolean     @default(false)
  mercurialeRef String?
  createdAt     DateTime    @default(now())
  restaurant    Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, dismissed])
  @@map("news_items")
}

model NewsletterSubscriber {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  subscribedAt DateTime @default(now())
  unsubscribed Boolean  @default(false)

  @@map("newsletter_subscribers")
}

model CustomerFeedback {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  rating       Int
  comment      String?
  source       String     @default("app")
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
  @@map("customer_feedback")
}
