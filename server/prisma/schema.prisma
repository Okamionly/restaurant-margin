generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("chef") // admin, chef
  createdAt    DateTime @default(now())

  @@map("users")
}

model Supplier {
  id           Int      @id @default(autoincrement())
  name         String
  phone        String?
  email        String?
  address      String?
  city         String?
  postalCode   String?
  region       String?
  country      String   @default("France")
  siret        String?
  website      String?
  notes        String?
  categories   String[]
  contactName  String?
  delivery     Boolean  @default(true)
  minOrder     String?
  paymentTerms String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  ingredients  Ingredient[]

  @@map("suppliers")
}

model Ingredient {
  id           Int                @id @default(autoincrement())
  name         String
  unit         String
  pricePerUnit Float
  supplier     String?
  supplierId   Int?
  supplierRef  Supplier?          @relation(fields: [supplierId], references: [id])
  category     String
  allergens    String[]           @default([])
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  recipes      RecipeIngredient[]
  inventoryItem InventoryItem?

  @@map("ingredients")
}

model Recipe {
  id               Int                @id @default(autoincrement())
  name             String
  category         String
  sellingPrice     Float
  nbPortions       Int                @default(1)
  description      String?
  prepTimeMinutes  Int?
  cookTimeMinutes  Int?
  laborCostPerHour Float              @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  ingredients      RecipeIngredient[]

  @@map("recipes")
}

model RecipeIngredient {
  id           Int        @id @default(autoincrement())
  recipeId     Int
  ingredientId Int
  quantity     Float
  wastePercent Float      @default(0)
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([recipeId, ingredientId])
  @@map("recipe_ingredients")
}

model InventoryItem {
  id                  Int        @id @default(autoincrement())
  ingredientId        Int
  ingredient          Ingredient @relation(fields: [ingredientId], references: [id])
  currentStock        Float      @default(0)
  unit                String
  minStock            Float      @default(0)
  maxStock            Float?
  lastRestockDate     DateTime?
  lastRestockQuantity Float?
  notes               String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@unique([ingredientId])
  @@map("inventory_items")
}

model Invoice {
  id            Int           @id @default(autoincrement())
  supplierName  String
  invoiceNumber String
  invoiceDate   String
  totalAmount   Float
  status        String        @default("pending")
  createdAt     DateTime      @default(now())
  items         InvoiceItem[]

  @@index([supplierName])
  @@index([status])
  @@map("invoices")
}

model InvoiceItem {
  id           Int      @id @default(autoincrement())
  invoiceId    Int
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productName  String
  quantity     Float
  unit         String
  unitPrice    Float
  total        Float
  ingredientId Int?

  @@index([invoiceId])
  @@map("invoice_items")
}

model PriceHistory {
  id           Int      @id @default(autoincrement())
  ingredientId Int
  price        Float
  date         String
  source       String   @default("manual")
  createdAt    DateTime @default(now())

  @@index([ingredientId])
  @@index([date])
  @@index([ingredientId, date])
  @@map("price_history")
}

model MenuSale {
  id         Int      @id @default(autoincrement())
  recipeId   Int
  recipeName String
  quantity   Int
  revenue    Float
  date       String
  createdAt  DateTime @default(now())

  @@index([recipeId])
  @@index([date])
  @@index([recipeId, date])
  @@map("menu_sales")
}

model Conversation {
  id           String    @id
  name         String
  participants String[]
  lastMessage  String    @default("")
  unreadCount  Int       @default(0)
  isGroup      Boolean   @default(false)
  avatar       String    @default("")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  messages     Message[]

  @@map("conversations")
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  senderName     String
  content        String
  timestamp      String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@map("messages")
}
