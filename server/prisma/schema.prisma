generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                Int                @id @default(autoincrement())
  email             String             @unique
  passwordHash      String
  name              String
  role              String             @default("chef") // admin, chef
  emailVerified     Boolean            @default(true)
  verificationToken String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  acceptedCguAt     DateTime?
  createdAt         DateTime           @default(now())
  ownedRestaurants  Restaurant[]       @relation("OwnedRestaurants")
  memberships       RestaurantMember[]

  @@map("users")
}

model Restaurant {
  id            Int                @id @default(autoincrement())
  name          String
  address       String?
  cuisineType   String?
  phone         String?
  coversPerDay  Int                @default(80)
  ownerId       Int
  owner         User               @relation("OwnedRestaurants", fields: [ownerId], references: [id])
  members       RestaurantMember[]
  ingredients   Ingredient[]
  recipes       Recipe[]
  suppliers     Supplier[]
  inventory     InventoryItem[]
  invoices      Invoice[]
  priceHistory  PriceHistory[]
  menuSales     MenuSale[]
  conversations Conversation[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@map("restaurants")
}

model RestaurantMember {
  id           Int        @id @default(autoincrement())
  userId       Int
  restaurantId Int
  role         String     @default("member") // owner, admin, member
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@index([userId])
  @@index([restaurantId])
  @@map("restaurant_members")
}

model Supplier {
  id           Int        @id @default(autoincrement())
  name         String
  phone        String?
  email        String?
  address      String?
  city         String?
  postalCode   String?
  region       String?
  country      String     @default("France")
  siret        String?
  website      String?
  notes        String?
  categories   String[]
  contactName  String?
  delivery     Boolean    @default(true)
  minOrder     String?
  paymentTerms String?
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  ingredients  Ingredient[]

  @@index([restaurantId])
  @@map("suppliers")
}

model Ingredient {
  id            Int                @id @default(autoincrement())
  name          String
  unit          String
  pricePerUnit  Float
  supplier      String?
  supplierId    Int?
  supplierRef   Supplier?          @relation(fields: [supplierId], references: [id])
  category      String
  allergens     String[]           @default([])
  restaurantId  Int
  restaurant    Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  recipes       RecipeIngredient[]
  inventoryItem InventoryItem?

  @@index([restaurantId, name])
  @@map("ingredients")
}

model Recipe {
  id               Int                @id @default(autoincrement())
  name             String
  category         String
  sellingPrice     Float
  nbPortions       Int                @default(1)
  description      String?
  prepTimeMinutes  Int?
  cookTimeMinutes  Int?
  laborCostPerHour Float              @default(0)
  restaurantId     Int
  restaurant       Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  ingredients      RecipeIngredient[]

  @@index([restaurantId, category])
  @@map("recipes")
}

model RecipeIngredient {
  id           Int        @id @default(autoincrement())
  recipeId     Int
  ingredientId Int
  quantity     Float
  wastePercent Float      @default(0)
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([recipeId, ingredientId])
  @@map("recipe_ingredients")
}

model InventoryItem {
  id                  Int        @id @default(autoincrement())
  ingredientId        Int
  ingredient          Ingredient @relation(fields: [ingredientId], references: [id])
  currentStock        Float      @default(0)
  unit                String
  minStock            Float      @default(0)
  maxStock            Float?
  lastRestockDate     DateTime?
  lastRestockQuantity Float?
  notes               String?
  restaurantId        Int
  restaurant          Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@unique([ingredientId])
  @@index([restaurantId])
  @@map("inventory_items")
}

model Invoice {
  id            Int           @id @default(autoincrement())
  supplierName  String
  invoiceNumber String
  invoiceDate   String
  totalAmount   Float
  status        String        @default("pending")
  restaurantId  Int
  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  items         InvoiceItem[]

  @@index([supplierName])
  @@index([status])
  @@index([restaurantId, createdAt])
  @@map("invoices")
}

model InvoiceItem {
  id           Int      @id @default(autoincrement())
  invoiceId    Int
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productName  String
  quantity     Float
  unit         String
  unitPrice    Float
  total        Float
  ingredientId Int?

  @@index([invoiceId])
  @@map("invoice_items")
}

model PriceHistory {
  id           Int        @id @default(autoincrement())
  ingredientId Int
  price        Float
  date         String
  source       String     @default("manual")
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@index([ingredientId])
  @@index([date])
  @@index([ingredientId, date])
  @@index([ingredientId, createdAt])
  @@map("price_history")
}

model MenuSale {
  id           Int        @id @default(autoincrement())
  recipeId     Int
  recipeName   String
  quantity     Int
  revenue      Float
  date         String
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@index([recipeId])
  @@index([date])
  @@index([recipeId, date])
  @@map("menu_sales")
}

model Conversation {
  id           String     @id
  name         String
  participants String[]
  lastMessage  String     @default("")
  unreadCount  Int        @default(0)
  isGroup      Boolean    @default(false)
  avatar       String     @default("")
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  messages     Message[]

  @@map("conversations")
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  senderName     String
  content        String
  timestamp      String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@map("messages")
}
